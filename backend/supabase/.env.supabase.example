# Supabase project refs — copy this file to .env.supabase and fill in the values
# Get these from: supabase.com → your project → Settings → General
#
# Project ref: the short ID in your project URL, e.g. abcdefghijklmnop
# DB password:  the password you set when creating the project (Settings → Database → Database password)

STAGING_PROJECT_REF=your-staging-project-ref
STAGING_DB_PASSWORD=your-staging-db-password

PROD_PROJECT_REF=your-prod-project-ref
PROD_DB_PASSWORD=your-prod-db-password
