# Staging secrets are NOT stored in env files.
# They live in GCP Secret Manager and are injected into Cloud Run at deploy time
# by the GitHub Actions workflow (.github/workflows/deploy-backend-staging.yml).
#
# Secret Manager keys → Cloud Run env vars:
#   AREX_STAGING_SUPABASE_URL              → SUPABASE_URL
#   AREX_STAGING_SUPABASE_PUBLISHABLE_KEY  → SUPABASE_PUBLISHABLE_KEY
#   AREX_STAGING_SUPABASE_SECRET_KEY       → SUPABASE_SECRET_KEY
#   AREX_STAGING_CORS_ORIGINS              → CORS_ORIGINS
#   AREX_STAGING_GCS_SA_JSON               → mounted at /secrets/gcs-sa.json
#
# Switch to the correct GCP project first:
#   gcloud config set project alex-494107
#
# To list all secrets:
#   gcloud secrets list --filter="name~AREX_STAGING" --project=alex-494107
#
# To add or rotate a secret:
#   echo -n "value" | gcloud secrets versions add AREX_STAGING_<KEY> --data-file=-
#
# To create a new secret for the first time:
#   echo -n "value" | gcloud secrets create AREX_STAGING_<KEY> --data-file=- --replication-policy=automatic
#
# Required GitHub Actions secrets (set in repo Settings → Secrets):
#   GCP_SA_KEY       — arex-github-deployer service account JSON key
#   GCP_PROJECT_ID   — GCP project ID
#   GCP_REGION       — e.g. asia-southeast1
