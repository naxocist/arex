# Copy to .env.staging on the GCP VM. Never commit .env.staging to git.
# Staging can share the same Supabase project as prod, or use a separate one.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Must include your Vercel staging preview URL for the staging branch
CORS_ORIGINS=["https://arex-platform-git-staging-yourteam.vercel.app"]
