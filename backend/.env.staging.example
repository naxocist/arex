# Copy to .env.staging on the GCP VM. Never commit .env.staging to git.
# Staging can share the same Supabase project as prod, or use a separate one.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Must include your Vercel staging preview URL for the staging branch
CORS_ORIGINS=["https://arex-platform-git-staging-yourteam.vercel.app"]

# Load test credentials (used by load_tests/ suite)
LOAD_TEST_TARGET_HOST=https://YOUR_STAGING_CLOUD_RUN_URL
LOAD_TEST_FARMER_EMAIL=farmer_a@demo.com
LOAD_TEST_FARMER_PASSWORD=Arex123!
LOAD_TEST_LOGISTICS_EMAIL=logistics_a@demo.com
LOAD_TEST_LOGISTICS_PASSWORD=Arex123!
LOAD_TEST_FACTORY_EMAIL=factory_a@demo.com
LOAD_TEST_FACTORY_PASSWORD=Arex123!
LOAD_TEST_WAREHOUSE_EMAIL=warehouse@gmail.com
LOAD_TEST_WAREHOUSE_PASSWORD=Arex123!
LOCUST_USERS=50
LOCUST_SPAWN_RATE=5
LOCUST_RUN_TIME=5m
