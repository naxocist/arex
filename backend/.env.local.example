# Copy to .env.local for local dev. Never commit .env.local to git.
APP_NAME=AREX Backend API
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173"]
SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_PUBLISHABLE_KEY=replace-with-local-or-hosted-publishable-key
SUPABASE_SECRET_KEY=replace-with-local-or-hosted-secret-key
