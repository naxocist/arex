# Frontend environment for this monorepo (React/Vite at repository root).
#
# Copy to .env.local for local development:
#   cp .env.example .env.local

# Backend API base URL used by frontend client calls.
VITE_API_BASE_URL="http://localhost:8000/api/v1"

# Optional app URL used by some hosted integrations.
APP_URL="http://localhost:3000"

# Optional Gemini API key for features that require it.
# Do NOT expose production secrets in frontend runtime variables.
GEMINI_API_KEY=""
